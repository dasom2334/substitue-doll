{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git push:*)",
      "Bash(npm test)",
      "Bash(ruff:*)",
      "Bash(pytest:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Edit(.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/review-reminder.sh\""
          }
        ]
      }
    ]
  }
}
